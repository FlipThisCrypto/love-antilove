{
  "notes": "Starter ComfyUI API workflow template. Replace checkpoint/model nodes with your installed SDXL or pixel-art model, then map POSITIVE_PROMPT, NEGATIVE_PROMPT, SEED, WIDTH, HEIGHT, and OUTPUT_PREFIX in scripts/generate_images.py if needed.",
  "recommended_models": [
    "SDXL pixel-art finetune or LoRA",
    "Pixel Art XL LoRA",
    "Transparent-background or background-removal node if available"
  ],
  "api_workflow": {
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": "SEED",
        "steps": 30,
        "cfg": 7.0,
        "sampler_name": "euler",
        "scheduler": "normal",
        "denoise": 1.0,
        "model": ["4", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["5", 0]
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "REPLACE_WITH_PIXEL_MODEL.safetensors"
      }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": "WIDTH",
        "height": "HEIGHT",
        "batch_size": 1
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "POSITIVE_PROMPT",
        "clip": ["4", 1]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "NEGATIVE_PROMPT",
        "clip": ["4", 1]
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["4", 2]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "OUTPUT_PREFIX",
        "images": ["8", 0]
      }
    }
  }
}
