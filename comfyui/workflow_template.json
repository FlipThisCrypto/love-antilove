{
  "notes": "Reference-guided img2img workflow tuned for DreamShaper XL Lightning plus local detail/fantasy SDXL LoRAs. POSITIVE_PROMPT, NEGATIVE_PROMPT, REFERENCE_IMAGE, SEED, WIDTH, HEIGHT, and OUTPUT_PREFIX are replaced by scripts/generate_images.py.",
  "recommended_models": [
    "SDXL pixel-art finetune or LoRA",
    "Pixel Art XL LoRA",
    "Transparent-background or background-removal node if available"
  ],
  "api_workflow": {
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": "SEED",
        "steps": 12,
        "cfg": 3.0,
        "sampler_name": "euler",
        "scheduler": "sgm_uniform",
        "denoise": 0.64,
        "model": ["11", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["13", 0]
      }
    },
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "DreamShaperXL_Lightning.safetensors"
      }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": "WIDTH",
        "height": "HEIGHT",
        "batch_size": 1
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "POSITIVE_PROMPT",
        "clip": ["11", 1]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "NEGATIVE_PROMPT",
        "clip": ["11", 1]
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["4", 2]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "OUTPUT_PREFIX",
        "images": ["8", 0]
      }
    },
    "10": {
      "class_type": "LoraLoader",
      "inputs": {
        "model": ["4", 0],
        "clip": ["4", 1],
        "lora_name": "extremely detailed.safetensors",
        "strength_model": 1.0,
        "strength_clip": 1.0
      }
    },
    "11": {
      "class_type": "LoraLoader",
      "inputs": {
        "model": ["10", 0],
        "clip": ["10", 1],
        "lora_name": "fantasy.safetensors",
        "strength_model": 0.8,
        "strength_clip": 0.8
      }
    },
    "12": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "REFERENCE_IMAGE"
      }
    },
    "13": {
      "class_type": "VAEEncode",
      "inputs": {
        "pixels": ["12", 0],
        "vae": ["4", 2]
      }
    }
  }
}
